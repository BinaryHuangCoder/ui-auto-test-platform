-- 测试用例表
DROP TABLE IF EXISTS ;
CREATE TABLE  (
  uid=1000(administrator) gid=1000(administrator) groups=1000(administrator),4(adm),24(cdrom),27(sudo),30(dip),46(plugdev),100(users) bigint(20) NOT NULL AUTO_INCREMENT COMMENT '用例 ID',
   varchar(50) NOT NULL COMMENT '用例编号',
   varchar(200) NOT NULL COMMENT '用例名称',
   text COMMENT '用例描述',
   varchar(50) DEFAULT NULL COMMENT '设计者',
   varchar(20) DEFAULT 'positive' COMMENT '用例性质：positive-正例，negative-反例',
   tinyint(4) NOT NULL DEFAULT '1' COMMENT '状态：0-禁用，1-启用',
   datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
   datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  PRIMARY KEY (uid=1000(administrator) gid=1000(administrator) groups=1000(administrator),4(adm),24(cdrom),27(sudo),30(dip),46(plugdev),100(users)),
  UNIQUE KEY  (),
  KEY  (),
  KEY  ()
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='测试用例表';

